{
  "appId": "com.sequencesurface.salestracker",
  "appName": "Sales Tracker Pro",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "Geolocation": {
      "permissions": ["location"]
    },
    "SpeechRecognition": {
      "permissions": ["microphone"]
    }
  }
}
